# Ignore everything by default — only the file types listed below are tracked.
*

# Allow traversal into all directories
!*/
.idea/
.vscode/

# ── Flutter build & tool directories (re-ignored after !*/ above) ─────────────
src/luma-web/build/
src/luma-web/.dart_tool/

# ── Tracked ───────────────────────────────────────────────────────────────────
!.gitignore
# Go
!*.go
!*.mod
!go.sum
!*.toml
# Config & docs
!*.md
!*.yml
!*.yaml
!*.sql
!*.example
!Dockerfile*
!.github/
# Flutter / Dart
!*.dart
!pubspec.lock
!*.arb
!analysis_options.yaml