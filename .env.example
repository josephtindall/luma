# ── Required ──────────────────────────────────────────────────────────────────
LUMA_DB_URL=postgres://luma_user:changeme@postgres:5432/luma?sslmode=disable&search_path=luma
LUMA_REDIS_URL=redis://redis:6379
LUMA_HAVEN_URL=http://auth:8080
LUMA_PUBLIC_URL=https://luma.local

# ── Haven (shared postgres instance, separate schema) ────────────────────────
HAVEN_DB_PASS=changeme
HAVEN_JWT_SIGNING_KEY=generate-with-haven-cli-generate-secrets

# ── Luma database ────────────────────────────────────────────────────────────
LUMA_DB_PASS=changeme

# ── Optional ─────────────────────────────────────────────────────────────────
LUMA_PORT=8002
LUMA_LOG_LEVEL=info
LUMA_MAX_UPLOAD_MB=100
