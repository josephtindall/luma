# ── Required ──────────────────────────────────────────────────────────────────
LUMA_DB_URL=postgres://luma_user:changeme@postgres:5432/luma?sslmode=disable&search_path=luma
LUMA_REDIS_URL=redis://redis:6379
LUMA_AUTH_URL=http://auth:8080
LUMA_PUBLIC_URL=https://luma.local

# ── Auth service (shared postgres instance, separate schema) ────────────────────────
LUMA_AUTH_DB_PASS=changeme
LUMA_AUTH_JWT_SIGNING_KEY=generate-with-luma-auth-cli-generate-secrets

# ── Luma database ────────────────────────────────────────────────────────────
LUMA_DB_PASS=changeme

# ── Optional ─────────────────────────────────────────────────────────────────
LUMA_PORT=8002
LUMA_LOG_LEVEL=info
LUMA_MAX_UPLOAD_MB=100
